; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Order Up!"
config/version="0.1.4"
run/main_scene="uid://bmgtrlfllvee4"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

IpAddress="*res://utils/IPAddress.tscn"
Config="*res://utils/config.tscn"
Datetime="*res://utils/datetime.tscn"
Random="*res://utils/random/random.tscn"
Classifier="*res://utils/classifier/classifier.tscn"
SocketManager="*res://utils/socket_manager.tscn"
SignalBus="*res://utils/signal_bus.tscn"
SensorLeakyBucket="*res://utils/sensor_leaky_bucket.tscn"
SensorDataStore="*res://utils/sensor_data_store.tscn"
MotionRecognition="*res://utils/motion_recognition/motion_recognition.tscn"
DBConn="*res://utils/data_access/db_conn/db_conn.tscn"
Shutdown="*res://utils/shutdown/shutdown.tscn"
AudioSettingsService="*res://utils/data_access/services/audio_settings_service.tscn"
RoomService="*res://utils/data_access/services/room_service.tscn"
DishService="*res://utils/data_access/services/dish_service.tscn"
MinigameService="*res://utils/data_access/services/minigame_service.tscn"
RecipeService="*res://utils/data_access/services/recipe_service.tscn"
SaveService="*res://utils/data_access/services/save_service.tscn"
DishCompletionService="*res://utils/data_access/services/dish_completion_service.tscn"
DBSeeder="*res://utils/data_access/db_seeder/db_seeder.tscn"
CSVToDict="*res://utils/csv_to_dict.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot-sqlite/plugin.cfg", "res://addons/yaml/plugin.cfg")

[input]

motion_hit={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":0,"key_label":81,"unicode":113,"location":0,"echo":false,"script":null)
]
}
